@page "/Check"
@rendermode InteractiveServer
@inject WeatherService WeatherService

<style>
    body, html {
        height: 100%;
        margin: 0;
    }

    .container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100%;
        width: 100%;
        padding: 0 20px;
    }

    .weather-card {
        width: 100%;
        background-color: #E5F6FB;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        font-family: Arial, sans-serif;
        color: #333;
        text-align: center;
    }

    .search-bar {
        display: flex;
        justify-content: center;
        margin-bottom: 20px;
        width: 100%;
    }

    .search-bar input {
        flex: 1;
        padding: 10px;
        border: none;
        border-radius: 5px;
        font-size: 16px;
        margin-right: 10px;
    }

    .search-bar button {
        padding: 10px;
        background-color: #007BFF;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
    }

    .temperature {
        font-size: 48px;
        font-weight: bold;
        margin: 20px 0;
    }

    .icon img {
        width: 80px;
        height: auto;
    }

    .forecast {
        margin-top: 20px;
        text-align: left;
    }

    .forecast-day {
        border-bottom: 1px solid #ddd;
        padding: 10px 0;
    }

    .forecast-day:last-child {
        border-bottom: none;
    }
</style>

<PageTitle>LiveWeather</PageTitle>

<div class="container">
    <div class="weather-card">
        <div class="search-bar">
            <input @bind="city" @onkeypress="HandleKeyPress" class="form-control" placeholder="Enter City" />
            <button @onclick="GetWeather" class="btn btn-primary">Search</button>
        </div>

        @if (weatherResponse != null)
        {
            <div class="current-weather">
                <h2>@weatherResponse.Location.Name</h2>
                <div class="temperature">@weatherResponse.Current.Temp_C°C</div>
                <p>Condition: @weatherResponse.Current.Condition.Text</p>
                <p>Wind: @weatherResponse.Current.Wind_Kph km/h (@weatherResponse.Current.Wind_Mph mph) from @weatherResponse.Current.Wind_Dir</p>
                <p>Humidity: @weatherResponse.Current.Humidity%</p>
                <div class="icon">
                    <img src="@("https:" + weatherResponse.Current.Condition.Icon)" alt="Weather Icon" />
                </div>
            </div>

            <div class="forecast">
                <h3>5-Day Forecast</h3>
                @foreach (var day in weatherResponse.Forecast.Forecastday)
                {
                    <div class="forecast-day">
                        <p>@day.Date: Max Temp: @day.Day.Maxtemp_C°C, Min Temp: @day.Day.Mintemp_C°C, Condition: @day.Day.Condition.Text</p>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private string city = "";
    private WeatherResponse? weatherResponse;

    async Task GetWeather()
    {
        if (!string.IsNullOrWhiteSpace(city))
        {
            weatherResponse = await WeatherService.Get5DayForecastAsync(city);
        }
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            GetWeather();
        }
    }
}
